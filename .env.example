# ===========================================================================
# anatomy-rag 環境變數範例（.env.example）
# ---------------------------------------------------------------------------
# 用法：  cp .env.example .env   然後依需要填值。
# 預設值已設定為「開發 / mock 模式」：encoder、LLM、auth 皆走 mock，
# 因此「無 GPU、無 OpenAI 金鑰」也能 `make up` 通過基礎設施 smoke test。
# 變數名稱對齊 docs/ARCHITECTURE.md 附錄 A、backend config.py、docker-compose.yml。
#
# 安全提醒：本檔會進版控，請勿在此填入「真實」金鑰／密碼（CI 會跑 gitleaks）。
#           下方的 *_dev_pw / minioadmin / change-me-in-prod 僅為本機開發佔位值，
#           production 一律改用強密碼並透過 KMS/Doppler/Vault 注入（§6.9）。
# ===========================================================================

# ---- 開發 / mock 旗標（dev 預設全開，可獨立關閉以接真實服務）----
ENCODER_MOCK=true          # true=用決定性 mock /encode_query（不需 GPU）；接真實 ColPali 改 false
LLM_MOCK=true              # true=用 mock LLM（不需 OpenAI 金鑰）；接真實 OpenAI 改 false
AUTH_MODE=dev              # dev=注入固定 user_id 的 stub（DL-016 SSO 暫緩）；production 改 oidc
DEV_USER_ID=00000000-0000-0000-0000-000000000001   # dev stub 注入的固定學生 user_id

# ---- 資料庫（應用層 MUST 連 PgBouncer :6432；直連 :5432 僅限 migrations，§0.3）----
# 以下 hostname（pgbouncer/postgres）為 docker-compose 服務名；在容器內可解析。
# 若在宿主機直接跑（非容器），請改成 localhost。
DATABASE_URL=postgresql://anatomy:anatomy_dev_pw@pgbouncer:6432/anatomy_rag   # 經 PgBouncer（transaction pooling）
PG_DIRECT_URL=postgresql://anatomy:anatomy_dev_pw@postgres:5432/anatomy_rag   # 僅供 Alembic migrations 直連
# docker-compose 用來初始化 Postgres / PgBouncer 的憑證（須與上方 DSN 一致）：
POSTGRES_USER=anatomy
POSTGRES_PASSWORD=anatomy_dev_pw
POSTGRES_DB=anatomy_rag

# ---- Redis（語意快取 + token-bucket 限流）----
REDIS_URL=redis://redis:6379/0

# ---- LLM（OpenAI 標準付費 API；MUST NOT 用免費／個人版，§0.3）----
OPENAI_API_KEY=                              # LLM_MOCK=true 時可留空；接真實 LLM 時填 sk-proj-...
OPENAI_MODEL_PRIMARY=gpt-5.5                 # 主模型
OPENAI_MODEL_FALLBACK=gpt-5.4                # 連續 5xx/429 自動切備援
OPENAI_BASE_URL=https://api.openai.com/v1    # 預設值，通常不需改

# ---- 語意快取的 embedding ----
OPENAI_EMBED_MODEL=text-embedding-3-small    # DL-004：離線/評估用；快取去重用 small 即足夠
CACHE_LOCAL_EMBED_MODEL=intfloat/multilingual-e5-small   # DL-012：線上快取 lookup 用本地模型，免 OpenAI 往返
CACHE_DISTANCE_THRESHOLD=0.05                # redisvl cosine「距離」門檻（相似度 0.95 ≈ 距離 0.05）
CACHE_TTL_SECONDS=1209600                    # 快取存活秒數（14 天）

# ---- 評估 LLM（獨立金鑰，與生產分離）----
EVAL_OPENAI_API_KEY=                         # RAGAS 評估用；與 OPENAI_API_KEY 分開計費/隔離
EVAL_OPENAI_MODEL=gpt-5.5

# ---- ColPali Encoder 微服務 ----
COLPALI_PRIMARY_URL=http://encoder:8001/encode_query   # compose 服務名 encoder；正式環境為校內 GPU 主機
COLPALI_FALLBACK_URL=                                   # 選填：Modal 等備援 encoder endpoint
COLPALI_MODEL=vidore/colpali-v1.3-hf

# ---- 物件儲存（頁面圖片；dev 用 MinIO，prod 可換 S3 相容服務）----
S3_ENDPOINT=http://minio:9000               # compose 內 MinIO；正式可改 https://s3.amazonaws.com 等
S3_BUCKET=anatomy-rag-pages
S3_ACCESS_KEY=minioadmin                     # = MinIO MINIO_ROOT_USER（dev 佔位）
S3_SECRET_KEY=minioadmin                     # = MinIO MINIO_ROOT_PASSWORD（dev 佔位；prod 換強密碼）

# ---- 知識庫版本（所有 pages 查詢 MUST 帶 kb_version；dev 起手 1）----
ACTIVE_KB_VERSION=1

# ---- 校內 SSO（DL-016：v1 暫緩；AUTH_MODE=dev 時不需填）----
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_DISCOVERY_URL=        # 例：https://sso.school.edu.tw/.well-known/openid-configuration

# ---- 觀測（LangFuse 自託管 / Sentry）----
LANGFUSE_PUBLIC_KEY=                          # 由 LangFuse 介面產生後填入
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3100            # 對外 3100（DL-006，避開 Next.js :3000）
SENTRY_DSN=                                   # 留空則停用 Sentry
# 下列為 LangFuse 自身（docker-compose.observability.yml）所需；prod 務必改強值：
LANGFUSE_NEXTAUTH_SECRET=change-me-in-prod
LANGFUSE_SALT=change-me-in-prod
LANGFUSE_DB_PASSWORD=langfuse_dev_pw          # LangFuse 專用 Postgres 密碼（與主 DB 隔離）

# ---- 每使用者 / 全域限流（token bucket）----
RATE_LIMIT_PER_USER_MIN=15                    # 每使用者每分鐘上限
RATE_LIMIT_PER_USER_DAY=300                   # 每使用者每日上限
RATE_LIMIT_GLOBAL_RPS=20                      # 全域每秒請求上限

# ---- 選用旗標 ----
CLINICAL_FLAVORED_LOGGING=false               # §6.7 預設關閉（不做症狀攔截類記錄）
